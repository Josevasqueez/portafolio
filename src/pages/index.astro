---
import '../styles/global.css';
import Terminal from '../components/Terminal.astro';
import Icon from '../components/Icon.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Alejandro Vásquez // Lead Developer & Full-Stack Engineer</title>
    <meta
      name="description"
      content="Lead Developer & Full-Stack Engineer con 5+ años construyendo sistemas en producción. Node.js, React, PostgreSQL, AWS. Ingeniero en Informática."
    />
    <link rel="canonical" href="https://alejandrovasquez.dev" />

    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Alejandro Vásquez // Lead Developer & Full-Stack Engineer"
    />
    <meta
      property="og:description"
      content="Lead Developer & Full-Stack Engineer con 5+ años construyendo sistemas en producción. Node.js, React, PostgreSQL, AWS."
    />
    <meta property="og:image" content="/profile.jpg" />
    <meta property="og:url" content="https://alejandrovasquez.dev" />

    <meta name="twitter:card" content="summary" />
    <meta
      name="twitter:title"
      content="Alejandro Vásquez // Lead Developer & Full-Stack Engineer"
    />
    <meta
      name="twitter:description"
      content="Lead Developer & Full-Stack Engineer con 5+ años construyendo sistemas en producción. Node.js, React, PostgreSQL, AWS."
    />
    <meta name="twitter:image" content="/profile.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Alejandro Vásquez",
        "jobTitle": "Lead Developer & Full-Stack Engineer",
        "url": "https://alejandrovasquez.dev",
        "image": "/profile.jpg",
        "sameAs": ["https://linkedin.com/in/josevasqueez"]
      }
    </script>
  </head>
  <body class="font-body">
    <main class="max-w-2xl mx-auto px-6 py-16">
      <header class="mb-14">
        <div class="flex items-center gap-5">
          <img
            src="/profile.jpg"
            alt="Alejandro Vásquez"
            class="w-[100px] h-[100px] object-cover shrink-0 grayscale"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <div>
            <h1 class="font-title text-sm md:text-base leading-relaxed mb-2">
              Alejandro Vásquez
            </h1>
            <p class="text-muted text-xs md:text-sm mb-4">
              Lead Developer & Full-Stack Engineer
            </p>
            <div class="flex flex-wrap gap-2">
              <a
                href="https://linkedin.com/in/josevasqueez"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center border border-[var(--color-faint)] bg-[var(--color-badge)] w-7 h-7 hover:bg-[var(--color-faint)] transition-colors"
              >
                <Icon name="linkedin" size={16} />
              </a>
              <a
                href="https://wa.me/584126147025"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center border border-[var(--color-faint)] bg-[var(--color-badge)] w-7 h-7 hover:bg-[var(--color-faint)] transition-colors"
              >
                <Icon name="whatsapp" size={16} />
              </a>
              <a
                href="mailto:alejandrovasqueez@gmail.com"
                class="inline-flex items-center justify-center border border-[var(--color-faint)] bg-[var(--color-badge)] w-7 h-7 hover:bg-[var(--color-faint)] transition-colors"
              >
                <Icon name="mail" size={16} />
              </a>
            </div>
          </div>
        </div>
      </header>

      <section class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-9 h-9 border border-[var(--color-faint)] flex items-center justify-center shrink-0"
          >
            <Icon name="terminal" size={20} />
          </div>
          <h2
            class="font-title text-[10px] md:text-xs leading-relaxed text-muted"
          >
            // PERFIL
          </h2>
        </div>
        <p class="text-sm leading-relaxed mb-5">
          Lead Developer & Full-Stack Engineer con 5+ años construyendo sistemas
          en producción. Node.js, React, PostgreSQL, AWS (Lambdas, DynamoDB).
          Liderazgo técnico. IA como acelerador de desarrollo bajo supervisión
          propia.
        </p>
        <a
          href="/cv.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-3 py-2 text-xs font-title bg-[var(--color-text)] text-[var(--color-bg)] hover:opacity-80 transition-opacity"
        >
          <Icon name="file-text" size={14} />
          DESCARGAR CV
        </a>
      </section>

      <section class="mb-12">
        <div class="flex items-center gap-3 mb-5">
          <div
            class="w-9 h-9 border border-[var(--color-faint)] flex items-center justify-center shrink-0"
          >
            <Icon name="folder" size={20} />
          </div>
          <h2
            class="font-title text-[10px] md:text-xs leading-relaxed text-muted"
          >
            // PROYECTOS
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="border-b border-[var(--color-faint)]">
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 pr-3 font-normal"
                  >Nombre</th
                >
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 pr-3 font-normal"
                  >Tags</th
                >
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-right pb-2 font-normal"
                  >Url</th
                >
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-[var(--color-faint)]/50">
                <td class="py-3 pr-3 align-top">
                  <span class="text-sm">Proyecto Uno</span>
                </td>
                <td class="py-3 pr-3 align-top">
                  <div class="flex flex-wrap gap-1.5">
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >React</span
                    >
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >Node.js</span
                    >
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >PostgreSQL</span
                    >
                  </div>
                </td>
                <td class="py-3 align-top text-right">
                  <a
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-muted hover:text-[var(--color-text)] transition-colors external-link"
                  >
                    <Icon name="external-link" size={16} />
                  </a>
                </td>
              </tr>
              <tr class="border-b border-[var(--color-faint)]/50">
                <td class="py-3 pr-3 align-top">
                  <span class="text-sm">Proyecto Dos</span>
                </td>
                <td class="py-3 pr-3 align-top">
                  <div class="flex flex-wrap gap-1.5">
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >Next.js</span
                    >
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >Tailwind</span
                    >
                  </div>
                </td>
                <td class="py-3 align-top text-right">
                  <a
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-muted hover:text-[var(--color-text)] transition-colors external-link"
                  >
                    <Icon name="external-link" size={16} />
                  </a>
                </td>
              </tr>
              <tr class="border-b border-[var(--color-faint)]/50">
                <td class="py-3 pr-3 align-top">
                  <span class="text-sm">Proyecto Tres</span>
                </td>
                <td class="py-3 pr-3 align-top">
                  <div class="flex flex-wrap gap-1.5">
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >AWS</span
                    >
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >Lambda</span
                    >
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >DynamoDB</span
                    >
                  </div>
                </td>
                <td class="py-3 align-top text-right">
                  <a
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-muted hover:text-[var(--color-text)] transition-colors external-link"
                  >
                    <Icon name="external-link" size={16} />
                  </a>
                </td>
              </tr>
              <tr>
                <td class="py-3 pr-3 align-top">
                  <span class="text-sm">Proyecto Cuatro</span>
                </td>
                <td class="py-3 pr-3 align-top">
                  <div class="flex flex-wrap gap-1.5">
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >React Native</span
                    >
                    <span
                      class="text-[10px] border border-[var(--color-text)] bg-[var(--color-text)] px-1.5 py-0.5 text-[var(--color-bg)]"
                      >Firebase</span
                    >
                  </div>
                </td>
                <td class="py-3 align-top text-right">
                  <a
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-muted hover:text-[var(--color-text)] transition-colors external-link"
                  >
                    <Icon name="external-link" size={16} />
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-9 h-9 border border-[var(--color-faint)] flex items-center justify-center shrink-0"
          >
            <Icon name="briefcase" size={20} />
          </div>
          <h2
            class="font-title text-[10px] md:text-xs leading-relaxed text-muted"
          >
            // EXPERIENCIA PROFESIONAL
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="border-b border-[var(--color-faint)]">
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 pr-3 font-normal"
                  >Cargo</th
                >
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 pr-3 font-normal"
                  >Empresa</th
                >
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-right pb-2 font-normal"
                  >Periodo</th
                >
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-[var(--color-faint)]/50">
                <td class="py-3 pr-3"
                  ><span class="text-sm"
                    >Lead Developer & Full-Stack Engineer</span
                  ></td
                >
                <td class="py-3 pr-3 text-muted">Xinerlink</td>
                <td class="py-3 text-subtle text-xs text-right"
                  >2021 - Presente</td
                >
              </tr>
              <tr>
                <td class="py-3 pr-3"
                  ><span class="text-sm">Diseñador Web</span></td
                >
                <td class="py-3 pr-3 text-muted">Wizchimp / PI Marketing</td>
                <td class="py-3 text-subtle text-xs text-right">2017 - 2021</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-9 h-9 border border-[var(--color-faint)] flex items-center justify-center shrink-0"
          >
            <Icon name="university" size={20} />
          </div>
          <h2
            class="font-title text-[10px] md:text-xs leading-relaxed text-muted"
          >
            // FORMACIÓN ACADÉMICA
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="border-b border-[var(--color-faint)]">
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 pr-3 font-normal"
                  >Título</th
                >
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 pr-3 font-normal"
                  >Institución</th
                >
                <th
                  class="font-title text-[9px] leading-relaxed text-muted text-left pb-2 font-normal"
                  >Año</th
                >
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="py-3 pr-3 text-sm">Ing. en Informática</td>
                <td class="py-3 pr-3 text-muted"
                  >Universidad Alejandro de Humboldt, Caracas</td
                >
                <td class="py-3 text-subtle text-xs">2019</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <footer
        class="text-subtle text-xs border-t border-[var(--color-faint)] pt-6"
      >
        <span class="cursor-blink">© 2026 — Alejandro Vásquez</span>
      </footer>
    </main>

    <Terminal />
  </body>
</html>
