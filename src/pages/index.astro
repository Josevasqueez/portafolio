---
import '../styles/global.css';
import { site } from '../data/site';
import HeadSeo from '../components/HeadSeo.astro';
import Profile from '../components/Profile.astro';
import Bio from '../components/Bio.astro';
import Projects from '../components/Projects.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Terminal from '../components/Terminal.astro';
import CrtFlash from '../components/CrtFlash.astro';
---

<html lang={site.lang}>
  <head>
    <HeadSeo site={site} />
  </head>
  <body class="font-body">
    <main class="max-w-2xl mx-auto px-6 py-16">
      <Profile author={site.author} social={site.social} />
      <Bio bio={site.author.bio} cv={site.author.cv} />
      <Projects projects={site.projects} />
      <Experience experience={site.experience} />
      <Education education={site.education} />
      <footer
        class="text-subtle text-xs border-t border-[var(--color-faint)] pt-6"
      >
        <span class="cursor-blink">&copy; 2026 — {site.author.name}</span>
      </footer>
    </main>

    <Terminal />
    <CrtFlash />
  </body>
</html>
